<component type="desktop-application">
	<id>org.acreetionos.MediaWriter.desktop</id>
	<launchable type="desktop-id">org.acreetionos.MediaWriter.desktop</launchable>
	<project_license>GPL-2.0+</project_license>
	<metadata_license>CC0-1.0</metadata_license>
	<name>AcreetionOS Media Writer</name>
	<summary>Create an AcreetionOS live USB drive</summary>
	<branding>
		<color type="primary" scheme_preference="light">#aad0ee</color>
		<color type="primary" scheme_preference="dark">#3c6eb4</color>
	</branding>
	<description>
		<p>A tool to create a bootable live USB drive with an edition of AcreetionOS. Not only can AcreetionOS Media Writer write an image to your flash drive, it can also download it for you. It offers official editions and community spins. It provides basic information about each of them to help you make the right choice.</p>
		<p>AcreetionOS Media Writer can also write other bootable ISOs loaded from your local disk.</p>
	</description>
	<keywords>
        <keyword>iso</keyword>
        <keyword>acreetionos</keyword>
        <keyword>usb</keyword>
        <keyword>writer</keyword>
        <keyword>live</keyword>
        <keyword>creator</keyword>
        <keyword>media</keyword>
    </keywords>
	<url type="homepage">https://gitlab.acreetionos.org/natalie/AcreetionMediaWriter</url>
	<screenshots>
		<screenshot type="default"><image type="source">https://gitlab.acreetionos.org/natalie/AcreetionMediaWriter/-/raw/main/dist/screenshots/linux_main.png</image></screenshot>
	    <screenshot><image type="source">https://gitlab.acreetionos.org/natalie/AcreetionMediaWriter/-/raw/main/dist/screenshots/linux_select_release.png</image></screenshot>
	</screenshots>
	<developer_name>Natalie</developer_name>
	<update_contact>natalie@acreetionos.org</update_contact>
	<content_rating type="oars-1.1"/>
</component>
