<RCC>
    <qresource prefix="/logos">
        <file alias="default">../Images/Logo_Transparent.png</file>
    </qresource>
    <qresource prefix="/">
        <file alias="metadata.json">data/assets/metadata.json</file>
        <file alias="releases.json">data/assets/releases.json</file>
        <file alias="downloadPageImage">../Images/Logo_Transparent.png</file>
        <file alias="mainPageImage">../Images/Logo_Transparent.png</file>
    </qresource>
</RCC>
